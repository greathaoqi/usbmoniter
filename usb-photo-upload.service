[Unit]
Description=USB Photo Auto Upload to Synology NAS
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/usb-photo-upload
ExecStart=/usr/bin/python3 /opt/usb-photo-upload/usb_photo_upload.py
Restart=always
RestartSec=10
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
