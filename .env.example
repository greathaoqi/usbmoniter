# Synology NAS Configuration
SYNOLOGY_HOST=192.168.1.100
SYNOLOGY_USER=username
SYNOLOGY_PORT=22
SYNOLOGY_REMOTE_PATH=/volume1/photo/

# DingTalk Robot Webhook
# Create a robot in your DingTalk group to get this URL
DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=your_access_token_here
# DingTalk Secret for signature verification (optional, leave empty if not using)
# When you enable signature verification in DingTalk robot, copy the secret here
DINGTALK_SECRET=

# Supported file extensions (comma separated, whitelist)
# Only files with these extensions will be processed
SUPPORTED_EXTENSIONS=.jpg,.jpeg,.png,.raw,.arw,.cr2,.nef,.heic,.mp4,.mov,.avi

# Specific folders to process (comma separated, case-insensitive)
# Leave empty to process all folders.
# Only files in these folders will be processed.
# Examples: DCIM,CC,DS for DJI/Canon/Sony cameras
# Example: SPECIFIC_FOLDERS=DCIM,CC,DS
SPECIFIC_FOLDERS=

# Behavior Settings
AUTO_UNMOUNT=true
NOTIFY_ON_SUCCESS=true
NOTIFY_ON_FAILURE=true

# Organize photos by shooting date: creates subdirectories like YYYY/YYYY-MM/filename
# Works for both photos (uses EXIF date) and videos (uses file modification time)
ORGANIZE_BY_DATE=true

# Installation directory (where state.json is stored)
INSTALL_DIR=/opt/usb-photo-upload
